<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="CShells Preview" value="https://f.feedz.io/valence-works/cshells/nuget/index.json" />
    <add key="Elsa 3 Preview" value="https://f.feedz.io/elsa-workflows/elsa-3/nuget/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="CShells Preview">
      <package pattern="CShells" />
      <package pattern="CShells.*" />
    </packageSource>
    <packageSource key="Elsa 3 Preview">
      <package pattern="Elsa.Platform.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>

