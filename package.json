{
  "name": "elsa-foundation-studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "check:bundle:workflows": "pnpm --filter @elsa-workflows/studio-workflows build",
    "test": "pnpm -r test",
    "test:browser": "playwright test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . && pnpm lint:css",
    "lint:css": "stylelint \"src/*/Client/src/**/*.css\" \"!src/Elsa.Studio.Web/**\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "stylelint": "^17.4.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.1.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
