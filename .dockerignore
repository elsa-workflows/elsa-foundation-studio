**/node_modules/
**/dist/
**/build/
**/coverage/
.pnpm-store/

# Local dev-only visual harness for the studio client
src/Elsa.Studio.Web/Client/harness/

# Git / VCS
.git/
.gitignore
**/.gitignore

# IDE / editor
.idea/
.vscode/
.vs/
*.user
*.suo

# OS / logs
.DS_Store
*.log

# Environment / secrets
.env*

# Docs and specs are not needed in the build context
docs/
specs/
.specify/
.github/
.agents/
.claude/

# The Dockerfile itself
**/Dockerfile
.dockerignore
