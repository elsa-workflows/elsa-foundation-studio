<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <StaticWebAssetBasePath>_content/Elsa.Studio.ConsoleStream</StaticWebAssetBasePath>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CShells.Abstractions" GeneratePathProperty="true" PrivateAssets="all" />
    <PackageReference Include="CShells.AspNetCore.Abstractions" GeneratePathProperty="true" />
    <PackageReference Include="ConsoleLogStreaming.AspNetCore" />
    <PackageReference Include="Elsa.Platform.PackageManifest.Generator" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Elsa.Studio.Core\Elsa.Studio.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Elsa.Studio.Tests" />
  </ItemGroup>

</Project>
