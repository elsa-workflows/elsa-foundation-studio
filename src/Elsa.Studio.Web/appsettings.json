{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CShells": {
    "Shells": {
      "Default": {
        "Features": {
          "StudioApi": {},
          "ConsoleStream": {
            "EndpointPrefix": "/_elsa/studio/diagnostics/console-logs",
            "RecentCapacity": 2000,
            "MaxRecentQuerySize": 2000,
            "PreserveAnsi": true
          },
          "FeatureManagement": {},
          "DashboardSample": false,
          "WeatherForecastSample": {}
        },
        "Configuration": {
          "WebRouting": {
            "Path": ""
          }
        }
      }
    }
  },
  "Studio": {
    "BackendBaseUrl": "https://localhost:7243"
  }
}
