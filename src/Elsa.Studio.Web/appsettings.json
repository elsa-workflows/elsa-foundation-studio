{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      // ShellMiddleware logs "Resolved shell ... for request path ..." at Information on every request. With the
      // console-stream feature capturing stdout, that per-request line feeds back into the stream it describes:
      // each hub transport request produces a line, which completes the next long poll immediately, which produces
      // another line — a request storm. Per-request shell resolution is Warning'd out for the same reason
      // Microsoft.AspNetCore is above.
      "CShells.AspNetCore.Middleware.ShellMiddleware": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Nuplane": {
    "Setup": {
      "AutomaticReconciliation": true,
      "PollInterval": "00:01:00",
      "Feeds": [
        {
          "Name": "studio-local-packages",
          "DirectoryPath": "packages",
          "IncludePatterns": [
            "*"
          ],
          "Directory": {
            "Watch": true,
            "DebounceWindow": "00:00:01"
          }
        }
      ]
    },
    "Loading": {
      "Enabled": true,
      "SharedAssemblies": [
        {
          "Name": "CShells.Abstractions",
          "PublicKeyToken": null,
          "MajorVersion": 0
        },
        {
          "Name": "CShells.AspNetCore.Abstractions",
          "PublicKeyToken": null,
          "MajorVersion": 0
        },
        {
          "Name": "Elsa.Studio.Core",
          "PublicKeyToken": null,
          "MajorVersion": 0
        }
      ]
    }
  },
  "Studio": {
    "BackendBaseUrl": "https://localhost:7243",
    "BackendModuleManagementApiKey": "local-dev-module-management-key"
  }
}
