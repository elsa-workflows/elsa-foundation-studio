{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Nuplane": {
    "Setup": {
      "AutomaticReconciliation": true,
      "PollInterval": "00:01:00",
      "Feeds": [
        {
          "Name": "studio-local-packages",
          "DirectoryPath": "packages",
          "IncludePatterns": [
            "*"
          ],
          "Directory": {
            "Watch": true,
            "DebounceWindow": "00:00:01"
          }
        }
      ]
    },
    "Loading": {
      "Enabled": true,
      "SharedAssemblies": [
        {
          "Name": "CShells.Abstractions",
          "PublicKeyToken": null,
          "MajorVersion": 0
        },
        {
          "Name": "CShells.AspNetCore.Abstractions",
          "PublicKeyToken": null,
          "MajorVersion": 0
        },
        {
          "Name": "Elsa.Studio.Core",
          "PublicKeyToken": null,
          "MajorVersion": 0
        }
      ]
    }
  },
  "Studio": {
    "BackendBaseUrl": "https://localhost:7243",
    "BackendModuleManagementApiKey": "local-dev-module-management-key"
  }
}
